# FinanSmart Central — Variables d'environnement
# Copier ce fichier vers .env pour le développement local :
#   cp .env.example .env
# En production (Railway), définir ces mêmes variables dans l'onglet "Variables".

# Injectée automatiquement par Railway quand un plugin PostgreSQL est attaché.
# En local, laisser vide pour retomber sur SQLite (finansmart_central_dev.db).
DATABASE_URL=

# Clé de signature interne (sessions, JWT). Générer avec :
#   python3 -c "import secrets; print(secrets.token_hex(32))"
FINANSMART_SECRET_KEY=ddcfbd4b598b7a34ac351393e979e5ad2a683f1947338f3b1fbb5927124bbde7

# Clé que CHAQUE poste FinanSmart utilise pour synchroniser avec ce serveur.
# Doit être identique à CENTRAL_API_KEY configurée côté client (desktop_app).
# Générer avec :
#   python3 -c "import secrets; print(secrets.token_hex(32))"
FINANSMART_CLIENT_API_KEY=080c4d282efca5f1a921648444eaf8c031b8efcbf4dd49ab7ca8c80a41556bf6

# Clé d'accès au dashboard admin central. Générer avec :
#   python3 -c "import secrets; print(secrets.token_hex(32))"
FINANSMART_ADMIN_API_KEY=3cff4553e99f07a7fc5bb20a924472c6532d9878cab965774c3c5327aa26f931

# development | production
FINANSMART_ENV=development

# (Optionnel, pour l'envoi des codes d'activation par email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=fs20project@gmail.com
SMTP_PASSWORD=blfepvhlxtfovmfy
